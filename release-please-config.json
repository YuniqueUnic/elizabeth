{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        },
        {
          "type": "toml",
          "path": "crates/board/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "crates/board-protocol/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "crates/configrs/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "crates/logrs/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value=='elizabeth-board')].version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value=='elizabeth-board-protocol')].version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value=='elizabeth-configrs')].version"
        },
        {
          "type": "toml",
          "path": "Cargo.lock",
          "jsonpath": "$.package[?(@.name.value=='elizabeth-logrs')].version"
        }
      ]
    }
  }
}
